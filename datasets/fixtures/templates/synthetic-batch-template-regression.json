          "page": 1,
          "block_types": [
            "heading"
          ]
        }
      },
      {
        "anchor_id": "yield-table",
        "kind": "table_header",
        "text": "Yield Summary",
        "match": "contains",
        "scope": {
          "page": 1,
          "block_types": [
            "table"
          ]
        }
      }
    ],
    "fields": [
      {
        "field_id": "batch_number",
        "label": "Batch No.",
        "value_type": "string",
