{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veridoc.local/schemas/document-ir-v1.schema.json",
  "title": "VeriDoc Document IR v1",
  "description": "Document IR v1 for Phase1 PoC parser-output conversion and structural validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document",
    "pages",
    "blocks",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "document-ir/v1"
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "source_type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "pdf",
            "docx",
            "xlsx",
            "unknown"
          ]
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "page_number",
          "width",
          "height",
          "unit"
        ],
        "properties": {
          "page_number": {
            "type": "integer",
            "minimum": 1
          },
          "width": {
            "type": "number",
            "minimum": 0
          },
          "height": {
            "type": "number",
            "minimum": 0
          },
          "unit": {
            "type": "string",
            "enum": [
              "pt",
              "px",
              "mm"
            ]
          }
        }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "text",
          "source_page",
          "bbox",
          "extractor",
          "confidence",
          "review"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "heading",
              "paragraph",
              "table",
              "field",
              "list_item"
            ]
          },
          "text": {
            "type": "string"
          },
          "source_page": {
            "type": "integer",
            "minimum": 1
          },
          "bbox": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "x",
              "y",
              "width",
              "height",
              "unit",
              "origin"
            ],
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0
              },
              "y": {
                "type": "number",
                "minimum": 0
              },
              "width": {
                "type": "number",
                "minimum": 0
              },
              "height": {
                "type": "number",
                "minimum": 0
              },
              "unit": {
                "type": "string",
                "enum": [
                  "pt",
                  "px",
                  "mm"
                ]
              },
              "origin": {
                "type": "string",
                "enum": [
                  "top-left"
                ]
              }
            }
          },
          "extractor": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "version"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              }
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "requires_review",
              "warnings"
            ],
            "properties": {
              "requires_review": {
                "type": "boolean"
              },
              "warnings": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
